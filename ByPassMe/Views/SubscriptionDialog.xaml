<Window x:Class="ByPassMe.Views.SubscriptionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подключение" Width="400" Height="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource SurfaceBrush}">
    <StackPanel Margin="24">
        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="🔑" FontSize="20" Margin="0,0,8,0"/>
            <TextBlock Text="Подключение" FontSize="20" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
        </StackPanel>

        <TextBlock Text="Вставьте ссылку подписки из вашей панели ByPassMe.&#x0a;Сохраняется один раз — больше не потребуется."
                   FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                   TextWrapping="Wrap" Margin="0,0,0,16"/>

        <TextBox x:Name="UrlInput" Style="{StaticResource ModernTextBox}"
                 AcceptsReturn="True" TextWrapping="Wrap"
                 MinHeight="70" MaxHeight="100" Margin="0,0,0,4"/>
        <TextBlock x:Name="ErrorText" Foreground="{StaticResource ErrorBrush}"
                   FontSize="12" Visibility="Collapsed" Margin="0,0,0,12"/>

        <Button x:Name="ApplyBtn" Content="Применить" Style="{StaticResource PrimaryButton}"
                Click="OnApply" Height="48"/>
    </StackPanel>
</Window>
