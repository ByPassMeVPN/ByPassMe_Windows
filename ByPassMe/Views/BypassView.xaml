<UserControl x:Class="ByPassMe.Views.BypassView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:ByPassMe.Controls"
             xmlns:conv="clr-namespace:ByPassMe.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="14,10,14,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Обход Б/С" FontSize="17" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            <Button x:Name="RefreshBtn" Grid.Column="1" Style="{StaticResource IconButton}"
                    Content="↻" Click="OnRefresh" ToolTip="Обновить серверы"/>
            <Button x:Name="KeyBtn" Grid.Column="2" Style="{StaticResource IconButton}"
                    Content="🔑" Click="OnShowSubscription" ToolTip="Подписка"/>
        </Grid>

        <controls:StatusBannerControl x:Name="StatusBanner" Grid.Row="1"/>

        <Grid Grid.Row="2" HorizontalAlignment="Center" Margin="0,8,0,12" Width="140" Height="140">
            <Ellipse x:Name="OrbOuter" Width="140" Height="140" Fill="{StaticResource OrbOuterBrush}"/>
            <Ellipse x:Name="OrbMiddle" Width="102" Height="102" Fill="{StaticResource OrbMiddleBrush}"/>
            <Ellipse x:Name="OrbInner" Width="70" Height="70" Fill="{StaticResource OrbOffBrush}"/>
            <TextBlock x:Name="OrbText" Text="OFF" FontSize="18" FontWeight="Black"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource SectionCard}" Padding="0,0,0,4" Margin="0,0,0,8">
            <StackPanel x:Name="ServerCardContent" ClipToBounds="True">
                <TextBlock Text="Сервер" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="14,10,14,4"/>
                <TextBlock x:Name="ServersEmptyText" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="14,8" Visibility="Collapsed"/>
                <ListBox x:Name="ServerList" BorderThickness="0" Background="Transparent"
                         SelectionChanged="OnServerSelected" Height="96" MaxHeight="96"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         ScrollViewer.CanContentScroll="False"
                         ClipToBounds="True">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Focusable" Value="True"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd" Height="48" Background="Transparent" Cursor="Hand">
                                            <ContentPresenter/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#0A000000"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#145B588D"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Height="48">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Image Width="28" Height="28" VerticalAlignment="Center"
                                       Margin="14,0,10,0" Source="{Binding FlagImage}"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                <TextBlock Grid.Column="1" Text="{Binding Country}" FontSize="14"
                                           VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Grid.Column="2" Text="✓" FontSize="14"
                                           Foreground="{StaticResource PrimaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,14,0"
                                           Visibility="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}, Converter={StaticResource BoolToVis}}"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Style="{StaticResource SectionCard}" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Ссылка VK звонка" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>
                <TextBox x:Name="VkInput" Style="{StaticResource ModernTextBox}"
                         TextChanged="OnVkChanged"/>
                <TextBlock x:Name="VkError" Text="Неверный формат ссылки"
                           Foreground="{StaticResource ErrorBrush}" FontSize="11"
                           Visibility="Collapsed" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="5" Style="{StaticResource SectionCard}" Margin="0,0,0,8">
            <StackPanel>
                <Grid>
                    <TextBlock Text="Мощность" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource PrimaryBrush}"/>
                    <TextBlock x:Name="WorkersLabel" Text="18" FontSize="12" FontWeight="Bold"
                               Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Right"/>
                </Grid>
                <Slider x:Name="WorkersSlider" Minimum="18" Maximum="36" Value="18"
                        TickFrequency="9" IsSnapToTickEnabled="True" IsMoveToPointEnabled="True"
                        ValueChanged="OnWorkersChanged" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>

        <Button x:Name="ConnectBtn" Grid.Row="7" Content="Подключить" Style="{StaticResource PrimaryButton}"
                Click="OnToggleConnect" VerticalAlignment="Bottom" Margin="0,4,0,0"/>
    </Grid>
</UserControl>
