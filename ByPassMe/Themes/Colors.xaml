<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Indigo light (default) — Android Theme.kt -->
    <Color x:Key="PrimaryColor">#5B588D</Color>
    <Color x:Key="PrimaryDarkColor">#4B487D</Color>
    <Color x:Key="OnPrimaryColor">#FFFFFF</Color>
    <Color x:Key="PrimaryContainerColor">#E2DFFF</Color>
    <Color x:Key="OnPrimaryContainerColor">#1A1744</Color>
    <Color x:Key="BackgroundColor">#FBF8FF</Color>
    <Color x:Key="SurfaceColor">#F6F3FA</Color>
    <Color x:Key="SurfaceVariantColor">#E4E1EC</Color>
    <Color x:Key="CardColor">#EEEAF4</Color>
    <Color x:Key="CardBorderColor">#3DC8C5D0</Color>
    <Color x:Key="TextPrimaryColor">#1B1B1F</Color>
    <Color x:Key="TextSecondaryColor">#47464F</Color>
    <Color x:Key="ErrorColor">#BA1A1A</Color>
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FFB300</Color>
    <Color x:Key="NavShellColor">#F5F3FA</Color>
    <Color x:Key="NavIndicatorColor">#F0EEFF</Color>
    <Color x:Key="NavBorderColor">#29C8C5D0</Color>
    <Color x:Key="OrbOuterColor">#265B588D</Color>
    <Color x:Key="OrbMiddleColor">#665B588D</Color>
    <Color x:Key="OrbOffColor">#E4E1EC</Color>
    <Color x:Key="InputBorderColor">#C8C5D0</Color>
    <Color x:Key="BackdropTopColor">#175B588D</Color>
    <Color x:Key="BackdropLeftColor">#3D5B588D</Color>
    <Color x:Key="BackdropBottomColor">#385B588D</Color>
    <Color x:Key="FloatingTabColor">#E2DFFF</Color>

    <!-- Terminal (Android WDTTColors) -->
    <Color x:Key="TerminalBgColor">#0D1117</Color>
    <Color x:Key="TerminalTextColor">#E6EDF3</Color>
    <Color x:Key="TerminalGreenColor">#AFF5B4</Color>
    <Color x:Key="TerminalBlueColor">#CBE0FF</Color>
    <Color x:Key="TerminalRedColor">#FF7B72</Color>
    <Color x:Key="TerminalYellowColor">#E3B341</Color>
    <Color x:Key="TerminalCounterColor">#8B949E</Color>
    <Color x:Key="TerminalVpnBadgeColor">#1F6FEB</Color>
    <Color x:Key="TerminalBypassBadgeColor">#238636</Color>
    <Color x:Key="TerminalServiceBadgeColor">#6E40C9</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}"/>
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="{StaticResource OnPrimaryColor}"/>
    <SolidColorBrush x:Key="PrimaryContainerBrush" Color="{StaticResource PrimaryContainerColor}"/>
    <SolidColorBrush x:Key="OnPrimaryContainerBrush" Color="{StaticResource OnPrimaryContainerColor}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="SurfaceVariantBrush" Color="{StaticResource SurfaceVariantColor}"/>
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}"/>
    <SolidColorBrush x:Key="CardBorderBrush" Color="{StaticResource CardBorderColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="NavShellBrush" Color="{StaticResource NavShellColor}"/>
    <SolidColorBrush x:Key="NavIndicatorBrush" Color="{StaticResource NavIndicatorColor}"/>
    <SolidColorBrush x:Key="NavBorderBrush" Color="{StaticResource NavBorderColor}"/>
    <SolidColorBrush x:Key="OrbOuterBrush" Color="{StaticResource OrbOuterColor}"/>
    <SolidColorBrush x:Key="OrbMiddleBrush" Color="{StaticResource OrbMiddleColor}"/>
    <SolidColorBrush x:Key="OrbOffBrush" Color="{StaticResource OrbOffColor}"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}"/>
    <SolidColorBrush x:Key="InputBgBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="BackdropTopGlowBrush" Color="{StaticResource BackdropTopColor}"/>
    <SolidColorBrush x:Key="BackdropLeftGlowBrush" Color="{StaticResource BackdropLeftColor}"/>
    <SolidColorBrush x:Key="BackdropBottomGlowBrush" Color="{StaticResource BackdropBottomColor}"/>
    <SolidColorBrush x:Key="FloatingTabBrush" Color="{StaticResource FloatingTabColor}"/>
    <SolidColorBrush x:Key="TerminalBgBrush" Color="{StaticResource TerminalBgColor}"/>
    <SolidColorBrush x:Key="TerminalTextBrush" Color="{StaticResource TerminalTextColor}"/>
    <SolidColorBrush x:Key="TerminalGreenBrush" Color="{StaticResource TerminalGreenColor}"/>
    <SolidColorBrush x:Key="TerminalBlueBrush" Color="{StaticResource TerminalBlueColor}"/>
    <SolidColorBrush x:Key="TerminalRedBrush" Color="{StaticResource TerminalRedColor}"/>
    <SolidColorBrush x:Key="TerminalYellowBrush" Color="{StaticResource TerminalYellowColor}"/>
    <SolidColorBrush x:Key="TerminalCounterBrush" Color="{StaticResource TerminalCounterColor}"/>
</ResourceDictionary>
