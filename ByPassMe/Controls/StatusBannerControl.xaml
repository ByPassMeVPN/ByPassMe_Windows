<UserControl x:Class="ByPassMe.Controls.StatusBannerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border x:Name="BannerBorder" CornerRadius="10" BorderThickness="1"
            Padding="12,9" Margin="0,0,0,10">
        <StackPanel Orientation="Horizontal">
            <TextBlock x:Name="IconText" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
            <TextBlock x:Name="MessageText" FontSize="12" FontWeight="Medium"
                       TextWrapping="Wrap" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
