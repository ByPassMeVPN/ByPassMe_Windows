<UserControl x:Class="ByPassMe.Controls.FloatingToolbarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="True">
    <Grid>
        <!-- Theme panel -->
        <Border x:Name="ThemePanel" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,180,52,0" Width="196" CornerRadius="32"
                Background="{StaticResource SurfaceBrush}" BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="1" Visibility="Collapsed" Padding="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.15"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Тема" FontSize="12" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,8"/>
                <Button x:Name="BtnSystem" Content="✨  Системная" Click="OnSystem" Style="{StaticResource ThemeOptionButton}"/>
                <Button x:Name="BtnLight" Content="☀  Светлая" Click="OnLight" Style="{StaticResource ThemeOptionButton}"/>
                <Button x:Name="BtnDark" Content="🌙  Тёмная" Click="OnDark" Style="{StaticResource ThemeOptionButton}"/>
                <Separator Margin="0,8" Background="{StaticResource CardBorderBrush}"/>
                <TextBlock Text="Палитра" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="4,0,0,8"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Ellipse x:Name="PalIndigo" Width="30" Height="30" Fill="#5B588D" Margin="6,0"
                             Cursor="Hand" MouseLeftButtonDown="OnIndigo"/>
                    <Ellipse x:Name="PalForest" Width="30" Height="30" Fill="#5F5D68" Margin="6,0"
                             Cursor="Hand" MouseLeftButtonDown="OnForest"/>
                    <Ellipse x:Name="PalEspresso" Width="30" Height="30" Fill="#6D4C41" Margin="6,0"
                             Cursor="Hand" MouseLeftButtonDown="OnEspresso"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Tab button -->
        <Border x:Name="TabButton" HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,180,0,0" Width="42" Height="52"
                CornerRadius="14,0,0,14" Background="{StaticResource FloatingTabBrush}"
                Cursor="Hand" MouseLeftButtonDown="OnTabClick">
            <Border.Effect>
                <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.18"/>
            </Border.Effect>
            <TextBlock Text="🎨" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</UserControl>
