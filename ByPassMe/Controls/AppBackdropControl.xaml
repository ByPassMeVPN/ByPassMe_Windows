<UserControl x:Class="ByPassMe.Controls.AppBackdropControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             IsHitTestVisible="False">
    <Grid Background="{StaticResource BackgroundBrush}">
        <Ellipse Width="258" Height="258" HorizontalAlignment="Left" VerticalAlignment="Top"
                 Margin="-86,-126,0,0" Fill="{StaticResource BackdropTopGlowBrush}"/>
        <Ellipse Width="146" Height="146" HorizontalAlignment="Left" VerticalAlignment="Center"
                 Margin="-44,28,0,0" Fill="{StaticResource BackdropLeftGlowBrush}"/>
        <Ellipse Width="198" Height="198" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                 Margin="0,0,62,208" Fill="{StaticResource BackdropBottomGlowBrush}"/>
    </Grid>
</UserControl>
